# Copy this file to .env.local and fill in your values

# Stripe — get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret — from `stripe listen --forward-to localhost:3000/api/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...

# Google AdSense — your publisher ID from https://adsense.google.com
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXXX

# Google Analytics 4 — Measurement ID from Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Your deployed site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://takehomepay.app

# Supabase (optional — for storing stub records and analytics)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
